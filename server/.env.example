# LiveKit Cloud — https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram (STT) — https://console.deepgram.com/
DEEPGRAM_API_KEY=

# OpenAI (LLM placeholder + TTS) — https://platform.openai.com
# The bridge replaces the OpenAI LLM with ADK on every turn; the key is
# only used by the TTS plugin to synthesize the agent's reply.
OPENAI_API_KEY=

# Google Gemini API — used by ADK to call Gemini directly (no GCP setup).
# Grab a free key in two minutes at https://aistudio.google.com/app/apikey.
GOOGLE_API_KEY=

# Optional: pick a different Gemini model. Default is gemini-2.5-flash.
DEMO_AGENT_MODEL=gemini-2.5-flash

# Optional — switch ADK to Vertex AI instead of the Gemini API. Leave
# unset for the simple path. If you flip this on, also set
# GOOGLE_CLOUD_PROJECT and GOOGLE_CLOUD_LOCATION and authenticate with
# `gcloud auth application-default login`.
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# Comma-separated origins allowed to call POST /token. The Vite dev
# server runs on :5173 by default.
CORS_ORIGINS=http://localhost:5173

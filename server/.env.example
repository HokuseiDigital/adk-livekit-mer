# LiveKit Cloud — https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram (STT) — https://console.deepgram.com/
DEEPGRAM_API_KEY=

# OpenAI (LLM placeholder + TTS) — https://platform.openai.com
# The bridge replaces the OpenAI LLM with ADK on every turn; the key is
# only used by the TTS plugin to synthesize the agent's reply.
OPENAI_API_KEY=

# Google Cloud / Vertex AI — needed by Google ADK to call Gemini.
# https://cloud.google.com/vertex-ai
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=1

# Optional: pick a different Gemini model. Default is gemini-2.5-flash.
DEMO_AGENT_MODEL=gemini-2.5-flash

# Comma-separated origins allowed to call POST /token. The Vite dev
# server runs on :5173 by default.
CORS_ORIGINS=http://localhost:5173
